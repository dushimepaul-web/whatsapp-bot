# PORT D'ÉCOUTE DU BACKEND
PORT=3001

# MONGODB — URI de connexion (Docker: mongodb://mongodb:27017/whatsapp-bot)
MONGODB_URI=mongodb://localhost:27017/whatsapp-bot

# JWT — GÉNÉRER DES CLÉS AVEC: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-secret-key
JWT_REFRESH_SECRET=change-this-to-another-random-secret-key
JWT_EXPIRE=1h
JWT_REFRESH_EXPIRE=7d

# WHATSAPP — PRÉFIXE DES COMMANDES
WHATSAPP_PREFIX=>

# RATE LIMIT — FENÊTRE (ms) ET MAX DE REQUÊTES
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# CORS — ORIGINE AUTORISÉE (ex: http://localhost:3000 ou domaine du frontend)
CORS_ORIGIN=http://localhost:3000
CONSOLE_ALLOWED_PHONES=25768863945,25779666439

# ENVIRONNEMENT — development | production
NODE_ENV=development
